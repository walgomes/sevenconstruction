# SevenConstruction — Postgres separado
# Banco proprio (sevenconstruction_db) no mesmo servidor Postgres local.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sevenconstruction_db

# Secret HMAC para assinatura de cookies (>= 16 chars). Trocar em producao.
SC_SECRET=troque-em-producao-pelo-menos-32-chars-aqui

# API key para scripts/MCP externos baterem em /api/* sem cookie.
SC_ADMIN_API_KEY=

NODE_ENV=development
