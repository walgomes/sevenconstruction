# =========================================================
# SevenConstruction — variaveis de ambiente
# =========================================================

# ------- Banco proprio -------
# Postgres do SevenConstruction (nao compartilha com sevendb do consultTudo).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sevenconstruction_db

# ------- RFB (read-only do consultTudo) -------
# Usado pelo prospec para listar empresas. Role sc_reader com GRANT SELECT em public.empresas.
CONSULTTUDO_DATABASE_URL=postgresql://sc_reader:SENHA@localhost:5432/sevendb

# ------- Cookie / Auth -------
# Secret HMAC para assinatura de cookies (>= 32 chars). Trocar em producao.
SC_SECRET=troque-em-producao-pelo-menos-32-chars-aqui

# ------- Admin / Cron -------
# Header x-sc-admin-key para scripts/MCP externos.
SC_ADMIN_API_KEY=

# Vercel Cron envia Authorization: Bearer ${CRON_SECRET} automaticamente.
# Set qualquer valor longo aleatorio aqui — usado pra autenticar /api/disparo/processar e /api/disparo/ia-gerar.
CRON_SECRET=

# ------- URL publica (link unsubscribe + webhook) -------
# Em prod: https://app.sevenconstruction.com.br (ou o que for)
SC_PUBLIC_URL=http://localhost:8800

# =========================================================
# Sprint 4 — Disparo (envio real)
# =========================================================

# ------- Resend (email) -------
# Criar conta em https://resend.com, adicionar dominio sevenconstruction.com.br,
# configurar DNS DKIM + SPF + DMARC. Apos verificacao do dominio:
RESEND_API_KEY=re_...
# From precisa ser de um dominio verificado:
RESEND_FROM_EMAIL="SevenConstruction <noreply@sevenconstruction.com.br>"

# Webhook Resend (opcional mas recomendado): em Resend Dashboard > Webhooks,
# criar endpoint apontando para https://<dominio>/api/disparo/webhook/resend
# e copiar o "Signing Secret" (comeca com whsec_):
RESEND_WEBHOOK_SECRET=whsec_...

# ------- WhatsApp Cloud API Meta -------
# 1) Criar app em https://developers.facebook.com (tipo Business)
# 2) Adicionar produto "WhatsApp"
# 3) Pegar PHONE_NUMBER_ID e TOKEN (System User token, longo prazo)
# 4) Cadastrar template aprovado pelo Meta — nome do template aqui:
META_WHATSAPP_TOKEN=EAAG...
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_TEMPLATE_NAME=outbound_lojaconstrucao_v1
# Versao da Graph API (atualiza eventualmente):
META_GRAPH_API_VERSION=v22.0

# Webhook Meta: em Meta Business Manager > WhatsApp > Configuration > Webhook,
# URL = https://<dominio>/api/disparo/webhook/meta
# Verify token = qualquer string nossa (gerar aleatoriamente, copiar nas 2 pontas):
META_WEBHOOK_VERIFY_TOKEN=
# App Secret do Meta (App Settings > Basic). Usado pra validar HMAC do header
# x-hub-signature-256 nos POSTs do webhook — sem isso qualquer um pode forjar eventos.
# Em prod, sem este valor o webhook devolve 500 e nao processa.
META_APP_SECRET=

# ------- IA marketing (Claude Haiku) -------
# https://console.anthropic.com — usado pra gerar 3 templates/dia/loja (~$0.001/loja).
ANTHROPIC_API_KEY=sk-ant-...

# ------- Resend (email transacional) -------
# https://resend.com/api-keys — API key
RESEND_API_KEY=
# Email FROM (precisa estar verificado no painel Resend)
RESEND_FROM_EMAIL=SevenConstruction <noreply@sevenconstruction.com.br>

# ------- Stripe (cobranca SaaS) -------
# https://dashboard.stripe.com/apikeys — secret key
STRIPE_SECRET_KEY=
# Cole o whsec_ do endpoint de webhook (Stripe Dashboard > Webhooks)
STRIPE_WEBHOOK_SECRET=
# Price IDs (criar no Stripe Dashboard > Products): cada plano = 1 price recorrente mensal
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# ------- Geral -------
NODE_ENV=development
